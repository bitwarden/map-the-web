{
  "name": "@bitwarden/map-the-web",
  "description": "Map the Web offers curated guidance for interacting with websites lacking rich semantics or fully-adopted standards.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitwarden/map-the-web.git"
  },
  "author": "Bitwarden Inc. <hello@bitwarden.com> (https://bitwarden.com)",
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://github.com/bitwarden/map-the-web/issues"
  },
  "private": true,
  "homepage": "https://bitwarden.com",
  "scripts": {
    "prepare": "husky",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check .",
    "lint:md": "remark . --frail --quiet",
    "lint:selectors": "node scripts/lint-selectors.mts",
    "typecheck": "tsc --noEmit",
    "validate": "node scripts/validate-schemas.mts",
    "check": "npm run prettier && npm run typecheck && npm run lint:md && npm run validate && npm run lint:selectors && npm test",
    "test": "node --test scripts/**/*.test.mts",
    "build": "node scripts/build.mts",
    "build:clean": "rm -rf dist && node scripts/build.mts"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=11"
  },
  "lint-staged": {
    "*.json": [
      "prettier --check"
    ],
    "maps/**/*.jsonc": [
      "node scripts/validate-schemas.mts"
    ],
    "maps/forms/*.jsonc": [
      "node scripts/lint-selectors.mts"
    ],
    "*.md": [
      "remark --frail --quiet"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "css-what": "8.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "remark-cli": "12.0.1",
    "remark-gfm": "4.0.1",
    "remark-github-blockquote-alert": "2.1.0",
    "remark-lint-no-trailing-spaces": "4.0.3",
    "remark-preset-lint-consistent": "6.0.1",
    "remark-preset-lint-recommended": "7.0.1",
    "strip-json-comments": "5.0.3",
    "typescript": "^6.0.3"
  }
}
